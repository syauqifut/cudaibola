# PostgreSQL connection string (Neon, Supabase, or local Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Highlightly Football API — used by cron sync job only (server-side)
HIGHLIGHTLY_API_KEY=

# Secret for protecting /api/cron/* routes (Vercel Cron sends this header)
CRON_SECRET=

# Interval sync worker saat tidak ada match live, dalam menit (default: 60)
SYNC_IDLE_INTERVAL_MINUTES=120
