# PostgreSQL connection string (Neon, Supabase, or local Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# football-data.org v4 API key — dipakai sync worker & cron (server-side only)
FOOTBALL_DATA_API_KEY=

# Secret untuk memproteksi endpoint trigger manual /api/cron/* (header Bearer)
CRON_SECRET=
